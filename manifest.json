{
  "manifest_version": 3,
  "name": "Firstlight",
  "version": "1.0.0",
  "description": "A personal dashboard for a calm, inspiring start to every browsing session.",
  "action": {
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
